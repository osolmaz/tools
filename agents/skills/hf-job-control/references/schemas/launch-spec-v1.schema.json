{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/osolmaz/hf-job-control/blob/main/schemas/launch-spec-v1.schema.json",
  "title": "HF Job Control launch specification v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "image", "command", "flavor", "timeout",
    "environment", "secret_names", "labels"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "image": {"type": "string", "minLength": 1, "maxLength": 500},
    "command": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "flavor": {"type": "string", "minLength": 1, "maxLength": 100},
    "timeout": {"type": "string", "minLength": 1, "maxLength": 100},
    "environment": {"type": "object", "additionalProperties": {"type": "string"}},
    "secret_names": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "labels": {"type": "object", "additionalProperties": {"type": "string"}},
    "namespace": {"type": "string", "minLength": 1}
  }
}
