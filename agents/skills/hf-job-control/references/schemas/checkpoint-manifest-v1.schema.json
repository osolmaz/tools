{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/osolmaz/hf-job-control/blob/main/schemas/checkpoint-manifest-v1.schema.json",
  "title": "HF Job Control checkpoint manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "run_id", "attempt_id", "adapter", "boundary",
    "payload_sha256", "payload_bytes", "created_at", "metadata"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "run_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},
    "attempt_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "resume_mode"],
      "properties": {
        "name": {"type": "string", "pattern": "^[a-z][a-z0-9_-]{0,63}$"},
        "version": {"type": "integer", "minimum": 1},
        "resume_mode": {"enum": ["exact", "boundary", "restart", "unsupported"]}
      }
    },
    "boundary": {"type": "object"},
    "payload_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "payload_bytes": {"type": "integer", "minimum": 0},
    "created_at": {"type": "string", "format": "date-time"},
    "metadata": {"type": "object"}
  }
}
