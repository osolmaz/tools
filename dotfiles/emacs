	(while (search-forward "\n" nil t) (replace-match "\r\n")))

;; Poor mans TTCN reader
(defun ttcn ()
  "Makes a trivial reformating of TTCN logs."
  (interactive)
  (goto-char (point-min))
  (while (search-forward "{" nil t) (replace-match "{\n\t"))
  (goto-char (point-min))
  (while (search-forward "," nil t) (replace-match ",\n\t"))
  (goto-char (point-min)))


