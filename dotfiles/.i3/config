# Make the currently focused window a scratchpad
bindsym $mod+m move scratchpad

# Show the first scratchpad window
bindsym F1 scratchpad show

# Show the sup-mail scratchpad window, if any.
# bindsym mod4+s [title="^Sup ::"] scratchpad show

# Startup programs
exec mate-power-manager
# exec gnome-power-manager
exec nm-applet
exec mate-volume-control-applet
# exec pasystray
exec /usr/lib/mate-settings-daemon/mate-settings-daemon
# exec /usr/lib/gnome-settings-daemon/gnome-settings-daemon
#exec urxvtd
exec dropboxd
exec conky
exec xfdesktop --class="pcmanfmdesktop"
# exec pcmanfm --desktop --class="pcmanfmdesktop"
#exec feh --bg-scale path_to_my_wallpaper.jpg # use if you don't use pcmanfm desktop
exec terminator -c fastterm


